---
import { SITE } from '../../constants/site';
import Icon from '../Icon.astro';
---

<a
  href={SITE.whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escríbenos por WhatsApp"
  class="fixed bottom-6 right-6 z-[70] flex h-[60px] w-[60px] items-center justify-center rounded-full bg-[#25D366] text-white shadow-[0_18px_36px_-8px_rgba(37,211,102,0.5)] transition-transform duration-200 hover:scale-110 hover:-rotate-6"
>
  <Icon name="whatsapp" size={28} strokeWidth={2} />
</a>
