---
import { STATS } from '../../../constants/content';
---

<section class="bg-evo-graphite py-20 text-white">
  <div class="wrap grid grid-cols-2 gap-y-8 lg:grid-cols-4 lg:gap-y-0">
    {
      STATS.map((stat, i) => (
        <div
          class:list={[
            'flex flex-col gap-2 px-5 lg:px-8',
            i % 2 === 0 ? 'border-l-0 lg:border-l lg:border-white/[0.12]' : 'border-l border-white/[0.12]',
            i === 0 && 'lg:!border-l-0 lg:!pl-0',
            i === 2 && 'border-l-0',
          ]}
        >
          <div class="text-[13px] font-medium uppercase tracking-[0.18em] text-evo-mint-300">{stat.label}</div>
          <div class="text-[clamp(48px,5vw,72px)] font-extralight leading-none tracking-[-0.03em] text-white">
            <span class="text-evo-mint">{stat.value}</span>
            {stat.suffix && <span class="text-[0.5em] text-white/50">{stat.suffix}</span>}
          </div>
          <div class="mt-1.5 text-sm leading-[1.5] text-white/55">{stat.description}</div>
        </div>
      ))
    }
  </div>
</section>
