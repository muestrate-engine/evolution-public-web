---
import { VALUES } from '../../../constants/content';
import { IMAGES } from '../../../constants/images';
import Button from '../../ui/Button.astro';
import Icon from '../../Icon.astro';
---

<section id="nosotros" class="bg-evo-bone py-20 md:py-[130px]">
  <div class="wrap grid grid-cols-1 items-center gap-20 lg:grid-cols-2">
    <!-- Arte superpuesto -->
    <div class="relative aspect-square">
      <div
        class="absolute left-0 top-0 aspect-[4/5] w-[65%] overflow-hidden rounded-[28px] shadow-[0_28px_60px_-20px_rgba(46,86,79,0.3)]"
        style="background: linear-gradient(160deg, #98CAC0, #467A6F);"
      >
        <img src={IMAGES.studioInterior} alt="Interior del studio Evolution" loading="lazy" decoding="async" class="absolute inset-0 h-full w-full object-cover opacity-90" />
        <div
          class="absolute left-6 top-6 z-[3] rounded-full bg-white/85 px-4 py-2.5 text-[11px] font-medium uppercase tracking-[0.24em] text-evo-mint-700 backdrop-blur-md"
        >
          Nuestro studio
        </div>
      </div>

      <div
        class="absolute bottom-0 right-0 flex aspect-square w-[55%] items-center justify-center overflow-hidden rounded-[28px] bg-evo-cream shadow-[0_28px_60px_-20px_rgba(46,86,79,0.18)]"
      >
        <svg viewBox="0 0 100 100" class="w-[60%]">
          <path
            d="M50 15 c-12 0 -20 8 -20 20 c0 9 2 16 2 26 c0 8 -2 14 -2 22 c0 9 5 14 10 14 c4 0 5 -4 5 -8 c0 -4 -1 -8 2 -8 c3 0 2 4 2 8 c0 4 1 8 5 8 c5 0 10 -5 10 -14 c0 -8 -2 -14 -2 -22 c0 -10 2 -17 2 -26 c0 -12 -8 -20 -20 -20z"
            fill="none"
            stroke="#5E9D90"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <div
        class="absolute right-[6%] top-[18%] flex items-center gap-3 rounded-[18px] bg-white px-[22px] py-[18px] shadow-[0_18px_36px_-10px_rgba(46,86,79,0.24)]"
      >
        <span class="flex h-[38px] w-[38px] items-center justify-center rounded-full bg-evo-mint-50 text-evo-mint-700">
          <Icon name="check-task" size={18} />
        </span>
        <div>
          <div class="text-[11px] uppercase tracking-[0.18em] text-fg-3">Certificado</div>
          <div class="text-[18px] text-fg">ISO 9001:2015</div>
        </div>
      </div>

      <div
        class="absolute bottom-[28%] -left-[8%] flex items-center gap-3 rounded-[18px] bg-evo-graphite px-[22px] py-[18px] text-white shadow-[0_18px_36px_-10px_rgba(46,86,79,0.3)]"
      >
        <span class="h-9 w-9 rounded-full" style="background: linear-gradient(135deg, #C8E3DC, #98CAC0);"></span>
        <div class="max-w-[180px] text-[13px] leading-[1.4]">
          "Te recibimos como <em class="italic text-evo-mint">familia</em>, no como un número."
        </div>
      </div>
    </div>

    <!-- Texto + valores -->
    <div>
      <div class="eyebrow">Quiénes somos</div>
      <h2 class="h-section">No es una clínica.<br />Es <em>un studio.</em></h2>
      <p class="lead">
        Evolution nace de una idea simple: el cuidado dental no tiene que sentirse frío. Diseñamos un
        espacio donde recibirte se parece más a visitar un atelier que un consultorio — luminoso,
        cómodo, sin prisa. Y donde explicarte todo es la regla, no la excepción.
      </p>
      <div class="mt-9 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {
          VALUES.map((v) => (
            <div class="flex gap-3.5 rounded-[18px] border border-line bg-white px-5 py-[18px]">
              <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl border border-evo-mint-100 bg-evo-mint-50 text-evo-mint-700">
                <Icon name={v.icon} size={18} />
              </span>
              <div>
                <h4 class="m-0 mb-1 text-[15px] font-medium tracking-[-0.005em] text-fg">{v.title}</h4>
                <p class="m-0 text-[13px] leading-[1.5] text-fg-2">{v.description}</p>
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-9 flex gap-3.5">
        <Button href="/equipo" variant="d" arrow>Conoce al equipo</Button>
      </div>
    </div>
  </div>
</section>
