---
import { EQ_PILLARS } from '../../../constants/equipo-page';
import Icon from '../../Icon.astro';
---

<section class="relative overflow-hidden bg-evo-graphite py-20 md:py-[130px] text-white">
  <div
    class="pointer-events-none absolute -bottom-[35%] -left-[12%] h-[720px] w-[720px]"
    style="background: radial-gradient(circle, rgba(152,202,192,0.16), transparent 62%);"
  >
  </div>
  <div class="wrap relative">
    <div class="max-w-[960px]">
      <div class="eyebrow !text-evo-mint before:!bg-evo-mint">Cómo trabajamos</div>
      <p class="m-0 text-[clamp(32px,4.2vw,58px)] font-extralight leading-[1.16] tracking-[-0.02em] text-white">
        No tratamos casos, tratamos personas. Cada decisión la tomamos
        <em class="italic text-evo-mint">en equipo y contigo</em> — porque la mejor odontología nace de
        escuchar antes de actuar.
      </p>
    </div>
    <div class="mt-[72px] grid grid-cols-1 gap-[18px] lg:grid-cols-3">
      {
        EQ_PILLARS.map((p) => (
          <div class="flex flex-col gap-3.5 rounded-[28px] border border-white/10 bg-white/[0.04] p-8 transition-all duration-300 hover:-translate-y-1 hover:bg-white/[0.07]">
            <div class="flex h-[52px] w-[52px] items-center justify-center rounded-2xl border border-evo-mint/30 bg-evo-mint/[0.16] text-evo-mint">
              <Icon name={p.icon} size={22} />
            </div>
            <div class="text-xs font-medium uppercase tracking-[0.18em] text-evo-mint-300">{p.tag}</div>
            <h3 class="m-0 text-2xl font-light tracking-[-0.015em] text-white">{p.title}</h3>
            <p class="m-0 text-[15px] leading-[1.6] text-white/65">{p.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
