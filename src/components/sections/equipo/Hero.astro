---
import { EQ_STATS } from '../../../constants/equipo-page';
import Button from '../../ui/Button.astro';
---

<section class="relative overflow-hidden py-20 pb-24">
  <img
    src="/img/brand/evolution-mark.svg"
    alt=""
    class="pointer-events-none absolute -right-[180px] -top-[120px] w-[580px] opacity-[0.06]"
  />
  <div class="wrap">
    <div class="max-w-[940px]">
      <div class="eyebrow">Nuestro equipo</div>
      <h1 class="m-0 mb-7 text-[clamp(48px,7vw,108px)] font-extralight leading-[0.96] tracking-[-0.035em] text-evo-graphite">
        Las manos y las<br />personas <em class="font-extralight not-italic text-evo-mint">detrás de tu sonrisa.</em>
      </h1>
      <p class="m-0 max-w-[620px] text-[22px] font-light leading-[1.55] text-fg-2">
        Especialistas que eligieron Evolution porque comparten una sola idea: el cuidado dental se
        hace mejor cuando es humano. Conócelos antes de sentarte en el sillón.
      </p>
      <div class="mt-9 flex flex-wrap gap-3.5">
        <Button href="/contacto" variant="p" arrow>Reserva con un especialista</Button>
        <Button href="#perfiles" variant="s">Ver perfiles</Button>
      </div>
    </div>

    <div class="mt-[72px] grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-4">
      {
        EQ_STATS.map((s) => (
          <div class="rounded-[24px] border border-line bg-white px-7 py-[30px]">
            <div class="text-[46px] font-extralight leading-none tracking-[-0.03em] text-evo-graphite">
              <em class="italic text-evo-mint">{s.value}</em>
              {s.suffix && <span class="text-[0.5em] text-fg-2">{s.suffix}</span>}
            </div>
            <div class="mt-3 text-[13px] uppercase tracking-[0.12em] text-fg-2">{s.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
