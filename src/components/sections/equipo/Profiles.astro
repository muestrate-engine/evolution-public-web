---
import { EQ_PROFILES } from '../../../constants/equipo-page';
---

<section id="perfiles" class="bg-evo-bone py-20 md:py-[130px]">
  <div class="wrap">
    <div class="eyebrow">Los especialistas</div>
    <h2 class="h-section">Quién te <em>atiende.</em></h2>
    <p class="lead mt-6">
      Cada profesional con nombre, trayectoria y formación. Para que sepas exactamente en manos de
      quién estás.
    </p>

    <div class="mt-14 flex flex-col gap-7">
      {
        EQ_PROFILES.map((p, i) => {
          const flip = i % 2 === 1;
          return (
            <article class="group grid grid-cols-1 overflow-hidden rounded-[32px] border border-line bg-white transition-all duration-300 hover:border-evo-mint hover:shadow-[0_30px_60px_-28px_rgba(46,86,79,0.24)] lg:grid-cols-[420px_1fr]">
              <div
                class:list={[
                  'relative min-h-[340px] overflow-hidden lg:min-h-[480px]',
                  flip && 'lg:order-2',
                ]}
                style={`background: ${p.gradient};`}
              >
                <img
                  src={p.photo}
                  alt={`${p.name} — ${p.role}`}
                  width="420"
                  height="520"
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-evo-mint-900/55 via-transparent to-transparent"></div>
                <div class="absolute left-[22px] top-[22px] rounded-full bg-white/90 px-4 py-2 text-[11px] font-medium uppercase tracking-[0.14em] text-evo-mint-700">
                  {p.role}
                </div>
                <div class="absolute bottom-6 left-6 text-white">
                  <div class="text-[44px] font-extralight leading-none tracking-[-0.03em]">{p.years}</div>
                  <div class="mt-1 text-xs uppercase tracking-[0.14em] opacity-85">de experiencia clínica</div>
                </div>
              </div>

              <div class:list={['flex flex-col p-9 lg:p-11', flip && 'lg:order-1']}>
                <h3 class="m-0 mb-1.5 text-[34px] font-light tracking-[-0.02em] text-evo-graphite">{p.name}</h3>
                <div class="text-[15px] font-medium tracking-[-0.01em] text-evo-mint-700">{p.specialty}</div>
                <p class="mb-0 mt-5 max-w-[560px] text-base leading-[1.62] text-fg-2">{p.bio}</p>

                <div class="mt-7 grid grid-cols-1 gap-8 border-t border-line pt-7 sm:grid-cols-2">
                  {[
                    { h: 'Experiencia', items: p.experience },
                    { h: 'Formación', items: p.education },
                  ].map((col) => (
                    <div>
                      <div class="mb-4 text-[11px] font-medium uppercase tracking-[0.22em] text-fg-2">{col.h}</div>
                      <ul class="m-0 flex list-none flex-col gap-3.5 p-0">
                        {col.items.map((it) => (
                          <li class="grid grid-cols-[56px_1fr] items-baseline gap-3.5">
                            <span class="text-[15px] tracking-[-0.01em] text-evo-mint-600">{it.yr}</span>
                            <span class="text-[14.5px] leading-[1.45] text-evo-graphite">
                              {it.text}
                              {it.sub && <small class="mt-0.5 block text-[12.5px] text-fg-2">{it.sub}</small>}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>

                <div class="mt-7 flex flex-wrap gap-2">
                  {p.credentials.map((c) => (
                    <span class="rounded-full border border-evo-mint-100 bg-evo-mint-50 px-3 py-1.5 text-xs font-medium text-evo-mint-700">
                      {c}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
