---
import type { CategorySectionData } from '../../../constants/tratamientos-page';

interface Props {
  data: CategorySectionData;
}
const { data } = Astro.props;
---

<section id={data.id} class:list={['py-20 md:py-[120px]', data.flip && 'bg-evo-cream']}>
  <div class="wrap grid grid-cols-1 items-center gap-[72px] lg:grid-cols-2">
    <div
      class:list={[
        'relative aspect-[4/3] overflow-hidden rounded-[32px] shadow-[0_30px_60px_-24px_rgba(46,86,79,0.25)]',
        data.flip ? 'lg:order-2' : 'lg:order-1',
      ]}
    >
      <img src={data.image} alt={data.tag} width="1000" height="750" loading="lazy" decoding="async" class="h-full w-full object-cover transition-transform duration-700 ease-out hover:scale-105" />
      <div class="absolute bottom-[22px] left-[22px] rounded-full bg-white/90 px-[18px] py-2.5 text-[11px] font-medium uppercase tracking-[0.2em] text-evo-mint-700 backdrop-blur-md">
        {data.tag}
      </div>
    </div>

    <div class:list={[data.flip ? 'lg:order-1' : 'lg:order-2']}>
      <div class="mb-4 text-sm font-medium uppercase tracking-[0.24em] text-evo-mint-600">{data.number}</div>
      <h2 class="m-0 mb-5 text-[clamp(36px,4.4vw,60px)] font-extralight leading-[1.04] tracking-[-0.025em] text-evo-graphite">
        {data.title}<br /><em class="italic text-evo-mint">{data.titleEm}</em>
      </h2>
      <p class="m-0 mb-8 text-[18px] font-light leading-[1.6] text-fg-2">{data.description}</p>
      <div class="flex flex-col">
        {
          data.services.map((s) => (
            <div class="flex items-center justify-between gap-5 border-b border-line py-4 last:border-b-0">
              <div class="flex items-center gap-3.5">
                <span class="h-[7px] w-[7px] flex-shrink-0 rounded-full bg-evo-mint" />
                <span class="text-[17px] tracking-[-0.01em] text-evo-graphite">{s.name}</span>
              </div>
              <span class="whitespace-nowrap text-[15px] font-medium text-evo-mint-700">{s.price}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
