---
import { TR_FAQ } from '../../../constants/tratamientos-page';
import { SITE } from '../../../constants/site';
import Button from '../../ui/Button.astro';
import Icon from '../../Icon.astro';
---

<section class="bg-evo-mint-50 py-20 md:py-[120px]">
  <div class="wrap grid grid-cols-1 items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
    <div class="lg:sticky lg:top-[110px]">
      <div class="eyebrow">Preguntas frecuentes</div>
      <h2 class="h-section">Lo que quizás<br /><em>te preguntas.</em></h2>
      <p class="lead mt-6">¿Otra duda? Escríbenos por WhatsApp — respondemos en menos de 30 minutos.</p>
      <Button href={SITE.whatsappUrl} variant="d" arrow class="mt-7" external>Escribir por WhatsApp</Button>
    </div>

    <div class="flex flex-col gap-2.5">
      {
        TR_FAQ.map((item, i) => (
          <details
            open={i === 0}
            class="group rounded-[18px] border border-line-soft bg-white px-7 py-6 transition-all duration-200 open:border-evo-mint-300 open:shadow-[var(--shadow-sm)]"
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-[18px] font-normal tracking-[-0.01em] text-evo-graphite [&::-webkit-details-marker]:hidden">
              {item.q}
              <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-evo-mint-50 text-evo-mint-700 transition-transform duration-200 group-open:rotate-45 group-open:bg-evo-mint group-open:text-evo-mint-900">
                <Icon name="cross" size={16} strokeWidth={2} />
              </span>
            </summary>
            <p class="mt-4 text-base leading-[1.6] text-fg-2">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
