---
import { TR_CASES } from '../../../constants/tratamientos-page';
---

<section class="bg-evo-bone py-20 md:py-[120px]">
  <div class="wrap">
    <div class="eyebrow">Casos reales</div>
    <h2 class="h-section">Antes y después,<br />de <em>pacientes reales.</em></h2>
    <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
      {
        TR_CASES.map((c) => (
          <article class="overflow-hidden rounded-[28px] border border-line bg-white">
            <div class="relative grid grid-cols-2">
              <div class="relative aspect-square overflow-hidden">
                <img src={c.before} alt="Antes" width="600" height="600" loading="lazy" decoding="async" class="h-full w-full object-cover" />
                <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3.5 py-1.5 text-[11px] font-medium uppercase tracking-[0.18em] text-fg-2">
                  Antes
                </span>
              </div>
              <div class="relative aspect-square overflow-hidden">
                <img src={c.after} alt="Después" width="600" height="600" loading="lazy" decoding="async" class="h-full w-full object-cover" />
                <span class="absolute left-4 top-4 rounded-full bg-evo-mint px-3.5 py-1.5 text-[11px] font-medium uppercase tracking-[0.18em] text-evo-mint-900">
                  Después
                </span>
              </div>
              <div class="absolute inset-y-0 left-1/2 z-[2] w-0.5 -translate-x-1/2 bg-white" />
            </div>
            <div class="px-[30px] py-7">
              <div class="text-xs font-medium uppercase tracking-[0.2em] text-evo-mint-700">{c.category}</div>
              <h4 class="my-2 text-2xl font-light tracking-[-0.015em] text-evo-graphite">{c.title}</h4>
              <p class="m-0 text-[15px] leading-[1.6] text-fg-2">{c.text}</p>
              <div class="mt-4 flex flex-wrap gap-4 border-t border-line pt-4 text-[13px] text-fg-3">
                {c.meta.map((m, i) => (
                  <>
                    {i === 0 ? <strong class="font-medium text-evo-mint-700">{m}</strong> : <span>{m}</span>}
                    {i < c.meta.length - 1 && <span>·</span>}
                  </>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
