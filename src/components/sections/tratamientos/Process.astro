---
import { TR_PROCESS } from '../../../constants/tratamientos-page';
---

<section class="relative overflow-hidden bg-evo-graphite py-20 md:py-[120px] text-white">
  <div
    class="pointer-events-none absolute -left-[12%] -top-[30%] h-[600px] w-[600px]"
    style="background: radial-gradient(circle, rgba(152,202,192,0.16), transparent 60%);"
  >
  </div>
  <div class="wrap relative">
    <div class="mx-auto mb-16 max-w-[720px] text-center">
      <div class="eyebrow justify-center !text-evo-mint before:!bg-evo-mint">Proceso de atención</div>
      <h2 class="m-0 text-[clamp(36px,4.4vw,60px)] font-extralight leading-[1.05] tracking-[-0.025em] text-white">
        Sin sorpresas, <em class="italic text-evo-mint">de principio a fin.</em>
      </h2>
    </div>
    <div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-4">
      {
        TR_PROCESS.map((step, i) => (
          <div class="rounded-[24px] border border-white/10 bg-white/[0.04] px-7 py-8">
            <div class="mb-[18px] flex h-12 w-12 items-center justify-center rounded-full border border-evo-mint/30 bg-evo-mint/[0.16] text-lg font-light text-evo-mint">
              {i + 1}
            </div>
            <h4 class="m-0 mb-2 text-xl font-normal tracking-[-0.01em] text-white">{step.title}</h4>
            <p class="m-0 text-[14.5px] leading-[1.55] text-white/60">{step.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
