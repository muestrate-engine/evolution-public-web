---
import { TR_CATEGORY_PILLS } from '../../../constants/tratamientos-page';
import Icon from '../../Icon.astro';
---

<section class="bg-evo-mint-50 py-20 md:py-[110px]">
  <div class="wrap">
    <div class="eyebrow">Categorías</div>
    <h2 class="h-section">Cinco áreas,<br />un mismo <em>cuidado.</em></h2>
    <div class="mt-12 grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-5">
      {
        TR_CATEGORY_PILLS.map((cat) => (
          <a
            href={`#${cat.id}`}
            class="group flex flex-col gap-3.5 rounded-[24px] border border-line-soft bg-white px-6 py-7 transition-all duration-300 hover:-translate-y-1 hover:border-evo-mint hover:shadow-[0_24px_48px_-16px_rgba(46,86,79,0.2)]"
          >
            <div class="flex h-12 w-12 items-center justify-center rounded-[14px] border border-evo-mint-100 bg-evo-mint-50 text-evo-mint-700">
              <Icon name={cat.icon} size={22} />
            </div>
            <div class="text-[19px] font-normal tracking-[-0.01em] text-evo-graphite">{cat.name}</div>
            <div class="text-[13px] leading-[1.5] text-fg-2">{cat.text}</div>
            <div class="mt-auto flex items-center gap-1.5 text-[13px] font-medium text-evo-mint-700">
              Ver más <Icon name="arrow-right" size={14} strokeWidth={2} />
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
