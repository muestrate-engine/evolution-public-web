---
import { TS_FEATURED_MAIN, TS_FEATURED_SIDE } from '../../../constants/testimonios-page';
import { splitQuote } from '../../../utils/text';
import Icon from '../../Icon.astro';

const main = splitQuote(TS_FEATURED_MAIN.quote, TS_FEATURED_MAIN.highlight);
---

<section class="relative overflow-hidden bg-evo-cream py-20 md:py-[120px] pb-[110px]">
  <div
    class="pointer-events-none absolute -right-[8%] -top-[12%] h-[520px] w-[520px]"
    style="background: radial-gradient(circle, rgba(152,202,192,0.32), transparent 62%);"
  >
  </div>
  <div class="wrap relative">
    <div class="mb-13">
      <div class="eyebrow">Destacados</div>
      <h2 class="h-section">Historias que<br /><em>nos quedaron grabadas.</em></h2>
    </div>
    <div class="grid grid-cols-1 gap-5 lg:grid-cols-[1.4fr_1fr]">
      <!-- Cita grande -->
      <div class="relative flex flex-col overflow-hidden rounded-[32px] bg-evo-graphite px-8 py-10 text-white sm:px-14 sm:py-13">
        <div class="h-14 font-serif text-[120px] font-light leading-[0.7] text-evo-mint">&ldquo;</div>
        <div class="mb-[22px] flex gap-1">
          {Array.from({ length: 5 }).map(() => <Icon name="star" size={18} class="fill-evo-mint" />)}
        </div>
        <p class="m-0 text-[clamp(24px,2.6vw,34px)] font-extralight leading-[1.34] tracking-[-0.02em]">
          {main.before}<em class="italic text-evo-mint">{main.mark}</em>{main.after}
        </p>
        <div class="mt-auto flex items-center gap-4 pt-9">
          <div
            class="flex h-13 w-13 items-center justify-center rounded-full text-[19px] text-evo-graphite"
            style="background: linear-gradient(135deg, #C8E3DC, #98CAC0); width:52px; height:52px;"
          >
            {TS_FEATURED_MAIN.initials}
          </div>
          <div>
            <div class="text-[17px] font-medium text-white">{TS_FEATURED_MAIN.name}</div>
            <div class="mt-0.5 text-[13px] text-white/60">{TS_FEATURED_MAIN.meta}</div>
          </div>
        </div>
      </div>

      <!-- Cards laterales -->
      <div class="flex flex-col gap-5">
        {
          TS_FEATURED_SIDE.map((card) => {
            const s = splitQuote(card.quote, card.highlight);
            return (
              <div class="flex flex-1 flex-col gap-4 rounded-[28px] border border-white/60 bg-white p-8 shadow-[0_10px_30px_-16px_rgba(46,86,79,0.12)]">
                <div class="flex gap-[3px]">
                  {Array.from({ length: 5 }).map(() => <Icon name="star" size={14} class="fill-evo-mint" />)}
                </div>
                <div class="text-[17px] font-light leading-[1.5] tracking-[-0.005em] text-evo-graphite">
                  "{s.before}<em class="italic text-evo-mint-700">{s.mark}</em>{s.after}"
                </div>
                <div class="mt-auto flex items-center gap-3 border-t border-line pt-4">
                  <div
                    class="flex h-10 w-10 items-center justify-center rounded-full text-[15px] font-medium text-white"
                    style="background: linear-gradient(135deg, #C8E3DC, #98CAC0);"
                  >
                    {card.initials}
                  </div>
                  <div>
                    <div class="text-sm font-medium text-fg">{card.name}</div>
                    <div class="text-xs text-fg-3">{card.meta}</div>
                  </div>
                  <Icon name="google" size={20} class="ml-auto" />
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
