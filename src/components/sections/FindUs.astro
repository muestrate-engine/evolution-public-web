---
import { SITE } from '../../constants/site';
import Icon from '../Icon.astro';
import MapArt from '../ui/MapArt.astro';

const cards = [
  {
    icon: 'map-pin',
    label: 'Dirección',
    value: SITE.address.street,
    sub: `${SITE.address.district}, ${SITE.address.city} ${SITE.address.postalCode}`,
    link: { href: SITE.address.mapsUrl, text: 'Cómo llegar →' },
  },
  {
    icon: 'clock-3',
    label: 'Horario',
    value: 'Lun – Vie · 9:00 a 19:00',
    sub: 'Sábado · 9:00 a 14:00 — Domingo cerrado',
  },
  {
    icon: 'whatsapp',
    label: 'WhatsApp',
    value: SITE.whatsapp,
    sub: 'Respuesta en menos de 30 minutos',
    link: { href: SITE.whatsappUrl, text: 'Escríbenos ahora →' },
  },
  {
    icon: 'mail',
    label: 'Email',
    value: SITE.email,
    sub: 'Para consultas formales y solicitudes',
  },
];
---

<section id="encuentranos" class="bg-evo-bone py-20 md:py-[130px]">
  <div class="wrap">
    <div class="eyebrow">Encuéntranos</div>
    <h2 class="h-section">En el corazón<br />de <em>Huancayo.</em></h2>
    <p class="lead mb-14">
      Estamos en pleno centro de Huancayo, en el Jr. Ica, con cafeterías y estacionamiento cerca para
      esperar (o celebrar) tu cita.
    </p>

    <div class="grid grid-cols-1 items-stretch gap-[60px] lg:grid-cols-[5fr_7fr]">
      <div class="flex flex-col gap-5">
        {
          cards.map((c) => (
            <div class="flex items-start gap-[18px] rounded-[24px] border border-line bg-white px-[30px] py-7">
              <span class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-[14px] border border-evo-mint-100 bg-evo-mint-50 text-evo-mint-700">
                <Icon name={c.icon} size={20} />
              </span>
              <div>
                <div class="mb-1.5 text-[11px] font-medium uppercase tracking-[0.24em] text-evo-mint-700">{c.label}</div>
                <div class="text-[17px] tracking-[-0.01em] text-fg">{c.value}</div>
                <small class="mt-1 block text-[13px] leading-[1.5] text-fg-2">{c.sub}</small>
                {c.link && (
                  <a
                    href={c.link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-2 inline-block text-[13px] font-medium text-evo-mint-700"
                  >
                    {c.link.text}
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Mapa estilizado -->
      <MapArt class="min-h-[480px]" />
    </div>
  </div>
</section>
