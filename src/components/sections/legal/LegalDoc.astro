---
import type { LegalDoc } from '../../../constants/legal';
import { SITE } from '../../../constants/site';
import Button from '../../ui/Button.astro';
import Icon from '../../Icon.astro';

interface Props {
  eyebrow: string;
  title: string;
  titleEm: string;
  doc: LegalDoc;
}
const { eyebrow, title, titleEm, doc } = Astro.props;
---

<!-- Encabezado -->
<section class="relative overflow-hidden border-b border-line py-20 pb-16">
  <img
    src="/img/brand/evolution-mark.svg"
    alt=""
    class="pointer-events-none absolute -right-[180px] -top-[120px] w-[560px] opacity-[0.05]"
  />
  <div class="wrap relative max-w-[900px]">
    <div class="eyebrow">{eyebrow}</div>
    <h1 class="m-0 mb-6 text-[clamp(40px,6vw,84px)] font-extralight leading-[0.98] tracking-[-0.035em] text-evo-graphite">
      {title}<br /><em class="font-extralight not-italic text-evo-mint">{titleEm}</em>
    </h1>
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-line bg-white px-4 py-2 text-[12.5px] font-medium text-fg-2">
      <Icon name="clock-3" size={14} class="text-evo-mint-700" />
      Última actualización: {doc.lastUpdated}
    </div>
    <p class="m-0 max-w-[680px] text-[18px] font-light leading-[1.6] text-fg-2">{doc.intro}</p>
  </div>
</section>

<!-- Índice + contenido -->
<section class="py-[90px]">
  <div class="wrap grid grid-cols-1 items-start gap-16 lg:grid-cols-[4fr_8fr]">
    <!-- Índice lateral -->
    <aside class="lg:sticky lg:top-[100px]">
      <div class="mb-4 text-[11px] font-medium uppercase tracking-[0.24em] text-evo-mint-700">Contenido</div>
      <nav class="flex flex-col gap-1 border-l border-line">
        {
          doc.sections.map((s) => (
            <a
              href={`#${s.id}`}
              class="-ml-px border-l-2 border-transparent py-1.5 pl-4 text-[14px] leading-snug text-fg-2 transition-colors hover:border-evo-mint hover:text-evo-mint-700"
            >
              {s.heading}
            </a>
          ))
        }
      </nav>

      <div class="mt-8 rounded-[20px] border border-evo-mint-100 bg-evo-mint-50 p-6">
        <div class="text-[15px] leading-[1.5] text-evo-graphite">
          <strong class="font-medium">¿Tienes alguna duda?</strong><br />Escríbenos y una persona real te
          responde.
        </div>
        <Button href={SITE.whatsappUrl} variant="d" arrow class="mt-4 !px-5 !py-3 !text-sm" external>
          Escríbenos
        </Button>
      </div>
    </aside>

    <!-- Cuerpo del documento -->
    <div class="max-w-[760px]">
      {
        doc.sections.map((s) => (
          <article id={s.id} class="scroll-mt-28 border-b border-line py-9 first:pt-0 last:border-b-0">
            <h2 class="m-0 mb-4 text-[24px] font-normal tracking-[-0.015em] text-evo-graphite sm:text-[28px]">
              {s.heading}
            </h2>
            <div class="flex flex-col gap-4">
              {s.blocks.map((b) =>
                b.type === 'list' ? (
                  <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
                    {b.items?.map((item) => (
                      <li class="flex gap-3 text-[16px] leading-[1.65] text-fg-2">
                        <span class="mt-[10px] h-[6px] w-[6px] flex-shrink-0 rounded-full bg-evo-mint" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="m-0 text-[16px] leading-[1.7] text-fg-2">{b.text}</p>
                )
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
